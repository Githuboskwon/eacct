{
    "name": "eacct-front",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "serve:local": "vue-cli-service serve --mode local",
        "serve": "vue-cli-service serve",
        "serve:production": "vue-cli-service serve --mode production",
        "build:local": "vue-cli-service serve --mode local",
        "build": "vue-cli-service build",
        "build:development": "vue-cli-service build --mode development",
        "build:staging": "vue-cli-service build --mode staging",
        "lint": "vue-cli-service lint",
        "test:unit": "vue-cli-service test:unit"
    },
    "dependencies": {
        "@babel/core": "^7.4.0",
        "@babel/plugin-transform-modules-commonjs": "^7.0.0",
        "@babel/plugin-transform-runtime": "^7.0.0",
        "@babel/polyfill": "^7.0.0",
        "@babel/preset-env": "^7.4.0",
        "@babel/runtime": "^7.0.0",
        "@babel/runtime-corejs2": "^7.4.3",
        "@xkeshi/image-compressor": "^0.5.3",
        "ag-charts-community": "^9.0.1",
        "ag-charts-vue": "^9.0.1",
        "ag-grid-community": "^25.1.0",
        "ag-grid-enterprise": "^25.1.0",
        "ag-grid-vue": "^25.1.0",
        "axios": "^0.18.1",
        "babel-plugin-dynamic-import-node": "^2.1.0",
        "babel-plugin-transform-runtime": "^6.23.0",
        "buefy": "^0.7.10",
        "bulma": "^0.7.4",
        "bulma-calendar": "^6.0.9",
        "bulma-carousel": "^4.0.4",
        "bulma-o-steps": "^1.0.9",
        "core-js": "^3.32.1",
        "cors": "^2.8.5",
        "cropperjs": "^1.5.7",
        "date-and-time": "^0.6.3",
        "date-fns": "^1.30.1",
        "element-ui": "^2.15.14",
        "from-cdn": "^1.0.1",
        "html2canvas": "^1.0.0-rc.5",
        "jquery": "^3.5.1",
        "jquery-ui": "^1.12.1",
        "lodash": "^4.17.19",
        "luxon": "^1.24.1",
        "mitt": "^3.0.1",
        "moment": "^2.27.0",
        "numeral": "^2.0.6",
        "promise-polyfill": "^8.1.3",
        "raw-loader": "4.0.2",
        "regenerator-runtime": "^0.14.0",
        "save": "^2.4.0",
        "sweetalert2": "^7.33.1",
        "swiper": "^4.5.1",
        "vue": "^2.7.16",
        "vue-class-component": "^7.2.3",
        "vue-cookie": "^1.1.4",
        "vue-i18n": "^8.22.2",
        "vue-loading-overlay": "^3.3.2",
        "vue-momentjs": "^0.1.2",
        "vue-pdf": "^4.1.0",
        "vue-property-decorator": "^9.0.0",
        "vue-router": "^3.3.4",
        "vue-sweetalert2": "^1.6.4",
        "vuex": "^3.5.1",
        "vuex-persistedstate": "^2.7.1",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^7.23.0",
        "@vue/cli-plugin-babel": "^5.0.8",
        "@vue/cli-plugin-eslint": "^5.0.8",
        "@vue/cli-plugin-unit-mocha": "^5.0.8",
        "@vue/cli-service": "^5.0.8",
        "@vue/eslint-config-airbnb": "^6.0.0",
        "@vue/test-utils": "^1.0.3",
        "babel-polyfill": "^6.26.0",
        "chai": "^4.2.0",
        "eslint": "^7.32.0",
        "eslint-plugin-import": "^2.25.3",
        "eslint-plugin-vue": "^8.0.0",
        "eslint-plugin-vuejs-accessibility": "^1.1.0",
        "expose-loader": "^0.7.5",
        "sass": "^1.49.7",
        "sass-loader": "^12.6.0"
    },
    "eslintConfig": {
        "root": true,
        "env": {
            "node": true
        },
        "extends": [
            "plugin:vue/essential",
            "@vue/airbnb",
            "eslint:recommended"
        ],
        "rules": {
            "no-empty": "off",
            "no-unused-vars": "off",
            "no-console": "off",
            "no-useless-escape": "off",
            "vue/no-unused-vars": "error",
            "vue/multi-word-component-names": "off",
            "vue/attributes-order": "off",
            "vue/max-attributes-per-line": "off",
            "vue/no-template-shadow": "off",
            "vue/v-bind-style": "off",
            "vue/require-default-prop": 0,
            "vue/require-explicit-emits": 0,
            "vue/html-self-closing": 0,
            "vue/html-closing-bracket-spacing": 0,
            "vue/first-attribute-linebreak": 0,
            "vue/html-closing-bracket-newline": 0,
            "vue/singleline-html-element-content-newline": 0,
            "vue/no-v-html": 0,
            "vue/no-useless-template-attributes": 0,
            "vue/no-mutating-props": 0,
            "vue/no-deprecated-filter": 0,
            "vue/no-deprecated-slot-attribute": 0,
            "vue/require-v-for-key": 0,
            "vue/no-use-v-if-with-v-for": 0,
            "vue/no-v-for-template-key-on-child": 0,
            "vue/no-deprecated-destroyed-lifecycle": 0,
            "vue/no-unused-components": 0,
            "vue/no-deprecated-v-on-native-modifier": 0,
            "import/extensions": 0,
            "import/no-extraneous-dependencies": 0,
            "import/no-unresolved": 0,
            "import/first": 0,
            "no-dupe-keys": 0
        },
        "globals": {
            "Ti": false,
            "Titanium": false,
            "Alloy": false,
            "$": false,
            "Backbone": false,
            "OS_IOS": false,
            "OS_ANDROID": false,
            "_": false,
            "ENV_DEV": false,
            "ENV_TEST": false,
            "ENV_PRODUCTION": false,
            "ENV_PROD": false,
            "DIST_ADHOC": false,
            "DIST_STORE": false,
            "L": false,
            "alert": false,
            "console": false,
            "Widget": false,
            "WPATH": false,
            "App": false,
            "Parse": true
        },
        "parserOptions": {
            "parser": "@babel/eslint-parser",
            "requireConfigFile": false
        }
    },
    "postcss": {
        "plugins": {
            "autoprefixer": {}
        }
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not ie <= 8"
    ],
    "overrides": {
        "websocket-driver": "0.7.4"
    },
    "element-theme": {
        "browsers": [
            "ie > 9",
            "last 2 versions"
        ],
        "out": "/theme",
        "config": "/src/assets/element-variables.scss",
        "theme": "element-theme-chalk",
        "minimize": true,
        "components": [
            "button",
            "input"
        ]
    },
    "volta": {
        "node": "18.20.8"
    }
}
